@using Atelie.Core.Resources;

<script src="~/Scripts/Atelie/Controllers/Account/account-index.js"></script>
<script>
    Atelie.Controller.Account.UrlLogar = '@Url.Action("Login", "Account")';
    Atelie.Controller.Account.UrlLogout = '@Url.Action("Logout", "Account")';
    Atelie.Controller.Account.UrlRedirecionarHome = '@Url.Action("Index", "Home")';
</script>

<section class="login-container">
    <div class="login-card">
        <form id="loginForm">
            <h2>@GlobalMessages.FacaLogin</h2>

            <div class="form-group">
                <label for="username">@GlobalMessages.Usuario</label>
                <input class="form-control" type="text" id="username" required />
            </div>

            <div class="form-group">
                <label for="password">@GlobalMessages.Senha</label>
                <input class="form-control" type="password" id="password" required />
            </div>

            <div class="d-grid gap-2 mt-4">
                <button class="btn btn-atelie-primario" type="submit" onclick="Atelie.Controller.Account.Logar()">
                    <i class="fas fa-sign-in-alt mr-2"></i> @GlobalMessages.Entrar
                </button>
            </div>
        </form>
    </div>
</section>